{
  "name": "cliff-notes",
  "version": "0.2.2",
  "private": true,
  "description": "Interactive playground for git-cliff configurations.",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "postinstall": "pnpm --filter @cliff-notes/shared run build",
    "build:shared": "pnpm --filter @cliff-notes/shared run build",
    "build": "pnpm -r run build",
    "dev": "pnpm build:shared && pnpm -r --parallel --filter=!@cliff-notes/e2e --filter=!cliff-toml-language run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm build:shared && pnpm -r run typecheck",
    "test": "pnpm build:shared && pnpm -r --filter=!@cliff-notes/e2e run test",
    "test:coverage": "pnpm build:shared && pnpm -r --filter=!@cliff-notes/e2e run test:coverage",
    "test:junit": "pnpm build:shared && pnpm -r --filter=!@cliff-notes/e2e run test:junit",
    "test:e2e": "pnpm --filter @cliff-notes/e2e run test",
    "clean": "pnpm -r run clean && rimraf coverage reports",
    "package:vsix": "pnpm --filter=@cliff-notes/tera-lang --filter=cliff-toml-language run clean && pnpm --filter=@cliff-notes/tera-lang --filter=cliff-toml-language run build && pnpm --filter=cliff-toml-language run package"
  },
  "cliffNotes": {
    "hashSeed": "cliff-notes-v1-9f2a7e4b1c8d3f6a0e5b2d9c4f7a1e8b"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
