{
  "comments": {
    "match": "#.*$",
    "name": "comment.line.number-sign.cliff-toml"
  },
  "brackets": [
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "[[",
      "close": "]]"
    },
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "{{",
      "close": "}}"
    },
    {
      "open": "{#",
      "close": "#}"
    },
    {
      "open": "{%",
      "close": "%}"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string"
      ]
    }
  ],
  "surroundingPairs": [
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    }
  ]
}
