{
  "name": "cliff-notes-tera-lang",
  "displayName": "Cliff.toml Tera Language",
  "description": "Syntax highlighting, snippets, completions, hover, and signature help for cliff.toml Tera templates",
  "version": "0.1.0",
  "publisher": "cliff-notes",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cliff-toml",
        "aliases": ["Cliff TOML", "cliff-toml"],
        "filenames": ["cliff.toml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cliff-toml",
        "scopeName": "source.cliff-toml",
        "path": "./node_modules/@cliff-notes/tera-lang/grammars/cliff-toml.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cliff-toml",
        "path": "./node_modules/@cliff-notes/tera-lang/snippets/tera.snippets.json"
      }
    ]
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "compile": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "@cliff-notes/tera-lang": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.8.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.0",
    "@vscode/vsce": "^3.9.1"
  }
}
