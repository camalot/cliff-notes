{
  "name": "@cliff-notes/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "site": {
    "repository": {
      "url": "https://github.com/camalot/cliff-notes"
    },
    "issues": {
      "url": "https://github.com/camalot/cliff-notes/issues"
    },
    "sponsor": {
      "url": "https://github.com/sponsors/camalot",
      "color": "#c45b95"
    },
    "coffee": {
      "url": "https://www.buymeacoffee.com/darthminos"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "dev": "vite --host",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured for web'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=junit --outputFile=../../reports/web-junit.xml",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@cliff-notes/shared": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "lz-string": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "@tailwindcss/postcss": "^4.3.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
