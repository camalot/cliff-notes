{
  "name": "@cliff-notes/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "cliff-notes": {
    "configurations": {
      "default.toml": {
        "description": "The default configuration for a cliff-notes playground."
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured for api'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=junit --outputFile=../../reports/api-junit.xml",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@cliff-notes/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "rimraf": "^6.1.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
